# Runtime mode: development | staging | production
AGENT_ORCH_ENV=development

# Required in staging/production.
AGENT_ORCH_API_KEY=change-me
AGENT_ORCH_ALLOWED_ORIGINS=https://your-frontend.example.com

# Optional rotation key (temporarily accepts old key):
# AGENT_ORCH_PREVIOUS_API_KEY=old-key-value

# Optional API rate limit per minute per client IP (0 disables):
AGENT_ORCH_RATE_LIMIT_PER_MIN=120

# Optional for local SQLite mode:
# AGENT_ORCH_DB_PATH=backend/data.db

# Optional Postgres mode:
# AGENT_ORCH_DATABASE_URL=postgresql://agent:agent@db:5432/agent_orch
